# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

kube_host           = "https://<control-plane-ip>:6443"
kube_ca_certificate = "<base64-encoded-ca-cert>"
kube_token          = "<service-account-token>"

# Traefik
traefik_dashboard_domain     = "traefik.example.com"
traefik_dashboard_basic_auth = "<htpasswd -nbB user password>"

# Let's Encrypt
letsencrypt_email   = "you@email.com"
letsencrypt_staging = true

# Cloudflare (DNS-01 solver for cert-manager)
cloudflare_api_token = "<cloudflare-api-token-with-dns-edit>"
